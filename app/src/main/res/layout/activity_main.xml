<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    ─────────────────
    The main screen. It has:
    • A full-screen camera preview at the back
    • A status bar at the top showing what mode the app is in
    • A large button at the bottom to describe the scene
    • A microphone button to listen for voice commands
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera preview fills the entire screen -->
    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/statusBar" />

    <!-- Semi-transparent overlay at top for status -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lumora VisionAid"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ready. Tap the button or say a command."
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <!-- Shows the current object being searched for -->
        <TextView
            android:id="@+id/tvSearchTarget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Description text shown after Gemini responds -->
    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#CC000000"
        android:padding="16dp"
        android:text=""
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:maxLines="6"
        app:layout_constraintBottom_toTopOf="@id/bottomControls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone" />

    <!-- Bottom control area -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="24dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row of mode buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <!-- Describe Scene button -->
            <Button
                android:id="@+id/btnDescribeScene"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="Describe"
                android:textSize="18sp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#2196F3"
                android:textStyle="bold"/>

            <!-- Find Object button -->
            <Button
                android:id="@+id/btnFindObject"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="Find Object"
                android:textSize="18sp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#4CAF50"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Voice Command button -->
        <Button
            android:id="@+id/btnVoiceCommand"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Hold for Voice Command"
            android:textSize="18sp"
            android:backgroundTint="#CA0000"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text='Say: "describe", "find [object]", "read text", "stop"'
            android:textColor="#88FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            />

    </LinearLayout>

    <!-- Loading spinner shown while Gemini is thinking -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:indeterminateTint="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone" />

    <androidx.constraintlayout.widget.Guideline android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

</androidx.constraintlayout.widget.ConstraintLayout>